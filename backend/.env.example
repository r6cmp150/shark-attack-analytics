# Supabase — find these in your Supabase project dashboard under Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_public_key
SUPABASE_SECRET_KEY=your_service_role_secret_key
SUPABASE_DB_PASSWORD=your_database_password

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# Server
PORT=3001

# Frontend origin for CORS (update to your Vercel URL in production)
FRONTEND_URL=http://localhost:5173
